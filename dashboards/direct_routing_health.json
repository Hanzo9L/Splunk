{
  "title": "Direct Routing & PSTN Health",
  "description": "Bank of America — Direct Routing migration health: Ribbon SBC performance, SIP response code analysis, trunk utilization, PSTN call volume, and failed call root cause.",
  "visualizations": {
    "viz_dr_success_rate": {
      "type": "splunk.singlevalue",
      "dataSources": { "primary": "ds_dr_success_rate" },
      "title": "DR Call Success Rate",
      "options": {
        "colorMode": "block",
        "majorColor": "#FFFFFF",
        "majorFontSize": 36,
        "unit": "%",
        "unitPosition": "after",
        "showTrendIndicator": true,
        "thresholds": {
          "fieldColors": {
            "ranges": [
              { "from": 0,  "to": 90, "value": "#C62828" },
              { "from": 90, "to": 95, "value": "#E65100" },
              { "from": 95, "to": 100,"value": "#2E7D32" }
            ]
          }
        }
      }
    },
    "viz_dr_call_count": {
      "type": "splunk.singlevalue",
      "dataSources": { "primary": "ds_dr_call_count" },
      "title": "DR Calls (Period)",
      "options": {
        "colorMode": "block",
        "backgroundColor": "#0D47A1",
        "majorColor": "#FFFFFF",
        "majorFontSize": 36,
        "showTrendIndicator": true
      }
    },
    "viz_pstn_call_count": {
      "type": "splunk.singlevalue",
      "dataSources": { "primary": "ds_pstn_call_count" },
      "title": "PSTN Calls (Period)",
      "options": {
        "colorMode": "block",
        "backgroundColor": "#1565C0",
        "majorColor": "#FFFFFF",
        "majorFontSize": 36,
        "showTrendIndicator": true
      }
    },
    "viz_avg_call_duration": {
      "type": "splunk.singlevalue",
      "dataSources": { "primary": "ds_avg_call_duration" },
      "title": "Avg Call Duration",
      "options": {
        "colorMode": "block",
        "backgroundColor": "#283593",
        "majorColor": "#FFFFFF",
        "majorFontSize": 36,
        "unit": " min",
        "unitPosition": "after"
      }
    },
    "viz_sip_response_codes": {
      "type": "splunk.bar",
      "dataSources": { "primary": "ds_sip_response_codes" },
      "title": "SIP Response Code Distribution",
      "options": {
        "xAxisTitleText": "SIP Code",
        "yAxisTitleText": "Call Count",
        "seriesColors": ["#1565C0","#D9534F","#F0AD4E","#5CB85C"],
        "showDataLabels": true,
        "legendDisplay": "none"
      }
    },
    "viz_dr_volume_trend": {
      "type": "splunk.line",
      "dataSources": { "primary": "ds_dr_volume_trend" },
      "title": "Direct Routing Call Volume Over Time",
      "options": {
        "xAxisTitleText": "Time",
        "yAxisTitleText": "Call Count",
        "seriesColors": ["#1565C0", "#D9534F"],
        "lineWidth": 2,
        "legendDisplay": "bottom",
        "nullValueDisplay": "connect"
      }
    },
    "viz_sbc_utilization": {
      "type": "splunk.column",
      "dataSources": { "primary": "ds_sbc_utilization" },
      "title": "Calls by SBC / Trunk",
      "options": {
        "xAxisTitleText": "SBC FQDN",
        "yAxisTitleText": "Call Count",
        "seriesColors": ["#1565C0"],
        "showDataLabels": true,
        "legendDisplay": "none"
      }
    },
    "viz_failed_calls_table": {
      "type": "splunk.table",
      "dataSources": { "primary": "ds_failed_calls_table" },
      "title": "Recent Failed Calls — Root Cause Analysis",
      "options": {
        "count": 20,
        "columnFormat": {
          "final_sip_code": {
            "data": {
              "type": "color",
              "scale": {
                "type": "range",
                "field": "final_sip_code",
                "ranges": [
                  { "from": 200, "to": 201, "background": "#E8F5E9" },
                  { "from": 400, "to": 499, "background": "#FFF3E0" },
                  { "from": 500, "to": 599, "background": "#FFCDD2" }
                ]
              }
            }
          }
        }
      }
    },
    "viz_pstn_by_direction": {
      "type": "splunk.pie",
      "dataSources": { "primary": "ds_pstn_by_direction" },
      "title": "PSTN Calls: Inbound vs Outbound",
      "options": {
        "showDonutHole": true,
        "legendDisplay": "right",
        "showPercent": true,
        "seriesColors": ["#1565C0", "#F57C00"]
      }
    },
    "viz_pstn_by_category": {
      "type": "splunk.column",
      "dataSources": { "primary": "ds_pstn_by_category" },
      "title": "PSTN Calls by Category",
      "options": {
        "xAxisTitleText": "Call Category",
        "yAxisTitleText": "Count",
        "seriesColors": ["#1565C0","#0288D1","#00897B"],
        "showDataLabels": true,
        "legendDisplay": "none"
      }
    },
    "viz_failure_by_stage": {
      "type": "splunk.bar",
      "dataSources": { "primary": "ds_failure_by_stage" },
      "title": "Failed Calls by Failure Stage",
      "options": {
        "xAxisTitleText": "Failure Stage",
        "yAxisTitleText": "Count",
        "seriesColors": ["#D9534F"],
        "showDataLabels": true,
        "legendDisplay": "none"
      }
    },
    "viz_dr_hourly_heatmap": {
      "type": "splunk.column",
      "dataSources": { "primary": "ds_dr_hourly_heatmap" },
      "title": "DR Call Volume by Hour of Day",
      "options": {
        "xAxisTitleText": "Hour (0-23)",
        "yAxisTitleText": "Calls",
        "seriesColors": ["#0D47A1"],
        "legendDisplay": "none"
      }
    }
  },
  "dataSources": {
    "ds_dr_success_rate": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:dr_record | eval success=if(final_sip_code==200 OR successfulCall==\"true\",1,0) | stats avg(success)*100 as success_rate | eval success_rate=round(success_rate,1)",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_dr_call_count": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:dr_record | stats count as dr_calls",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_pstn_call_count": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:pstn | stats count as pstn_calls",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_avg_call_duration": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls (sourcetype=teams:call:dr_record OR sourcetype=teams:call:pstn) | eval dur_min=duration_sec/60 | stats avg(dur_min) as avg_dur | eval avg_dur=round(avg_dur,1)",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_sip_response_codes": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:dr_record | lookup sip_response_code_lookup final_sip_code OUTPUT sip_description, sip_category | stats count by final_sip_code, sip_description, sip_category | eval label=final_sip_code.\" - \".sip_description | sort -count | head 20 | table label, count, sip_category",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_dr_volume_trend": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:dr_record | eval success=if(final_sip_code==200,\"Successful\",\"Failed\") | timechart span=1h count by success",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_sbc_utilization": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:dr_record | stats count as calls, avg(duration_sec) as avg_duration by trunkFullyQualifiedDomainName | lookup teams_trunk_metadata_lookup trunk_fqdn AS trunkFullyQualifiedDomainName OUTPUT sbc_name, carrier, region | eval sbc_label=coalesce(sbc_name, trunkFullyQualifiedDomainName), avg_duration=round(avg_duration/60,1) | sort -calls | table sbc_label, carrier, region, calls, avg_duration",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_failed_calls_table": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:dr_record | where final_sip_code!=200 AND successfulCall!=\"true\" | lookup sip_response_code_lookup final_sip_code OUTPUT sip_description | eval start=strftime(_time,\"%Y-%m-%d %H:%M:%S\") | table start, userPrincipalName, calleeNumber, trunkFullyQualifiedDomainName, final_sip_code, sip_description, failureStage, mediaBypassEnabled | sort -_time | head 20",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_pstn_by_direction": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:pstn | stats count by call_direction",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_pstn_by_category": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:pstn | stats count by call_category | sort -count",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_failure_by_stage": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:dr_record | where final_sip_code!=200 | stats count by failureStage | sort -count | head 10",
        "queryParameters": { "earliest": "$time.earliest$", "latest": "$time.latest$" }
      }
    },
    "ds_dr_hourly_heatmap": {
      "type": "ds.search",
      "options": {
        "query": "index=teams_calls sourcetype=teams:call:dr_record | eval hour=tonumber(strftime(_time,\"%H\")) | stats count by hour | sort hour",
        "queryParameters": { "earliest": "-7d@d", "latest": "now" }
      }
    }
  },
  "inputs": {
    "input_timerange": {
      "type": "input.timerange",
      "options": {
        "token": "time",
        "defaultValue": { "earliest": "-24h@h", "latest": "now" }
      },
      "title": "Time Range"
    },
    "input_sbc": {
      "type": "input.dropdown",
      "options": {
        "token": "sbc_filter",
        "defaultValue": "*",
        "items": [{ "label": "All SBCs", "value": "*" }],
        "labelField": "sbc_label",
        "valueField": "trunk_fqdn"
      },
      "title": "SBC / Trunk",
      "dataSources": {
        "primary": {
          "type": "ds.search",
          "options": {
            "query": "index=teams_calls sourcetype=teams:call:dr_record | lookup teams_trunk_metadata_lookup trunk_fqdn AS trunkFullyQualifiedDomainName OUTPUT sbc_name | eval sbc_label=coalesce(sbc_name,trunkFullyQualifiedDomainName), trunk_fqdn=trunkFullyQualifiedDomainName | stats count by sbc_label, trunk_fqdn"
          }
        }
      }
    }
  },
  "layout": {
    "type": "absolute",
    "options": {
      "width": 1440,
      "height": 1120,
      "display": "auto-scale"
    },
    "structure": [
      { "item": "viz_dr_success_rate",    "type": "block", "position": { "x": 20,  "y": 20,  "w": 330, "h": 120 } },
      { "item": "viz_dr_call_count",      "type": "block", "position": { "x": 370, "y": 20,  "w": 330, "h": 120 } },
      { "item": "viz_pstn_call_count",    "type": "block", "position": { "x": 720, "y": 20,  "w": 330, "h": 120 } },
      { "item": "viz_avg_call_duration",  "type": "block", "position": { "x": 1070,"y": 20,  "w": 350, "h": 120 } },
      { "item": "viz_dr_volume_trend",    "type": "block", "position": { "x": 20,  "y": 160, "w": 860, "h": 260 } },
      { "item": "viz_sip_response_codes", "type": "block", "position": { "x": 900, "y": 160, "w": 520, "h": 260 } },
      { "item": "viz_sbc_utilization",    "type": "block", "position": { "x": 20,  "y": 440, "w": 700, "h": 260 } },
      { "item": "viz_pstn_by_direction",  "type": "block", "position": { "x": 740, "y": 440, "w": 320, "h": 260 } },
      { "item": "viz_pstn_by_category",   "type": "block", "position": { "x": 1080,"y": 440, "w": 340, "h": 260 } },
      { "item": "viz_failure_by_stage",   "type": "block", "position": { "x": 20,  "y": 720, "w": 700, "h": 240 } },
      { "item": "viz_dr_hourly_heatmap",  "type": "block", "position": { "x": 740, "y": 720, "w": 680, "h": 240 } },
      { "item": "viz_failed_calls_table", "type": "block", "position": { "x": 20,  "y": 980, "w": 1400,"h": 300 } }
    ],
    "globalInputs": ["input_timerange", "input_sbc"]
  }
}
